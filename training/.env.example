# Copy this to training/.env (gitignored) and fill in.
#
# Sourced by training/scripts/run_grpo_{1,2}xa100.sh before launching, so the
# vars below are visible to the run_grpo.py overlay launcher and from there
# to wandb.init() / NeMo-RL's logger.

# Required for wandb logging (logger.wandb_enabled: true in our configs).
WANDB_API_KEY=

# Optional: override the W&B entity (team / username). If unset, wandb falls
# back to the API key's default entity.
# WANDB_ENTITY=

# Optional: override the W&B project name. The configs already default to
# "reason-over-search" (logger.wandb.project) — env var only useful
# if you want different values per run without editing the yaml.
# WANDB_PROJECT=reason-over-search

# Optional: pin a base directory for checkpoints. The bash wrappers default
# this to "results/grpo" (relative to repo root); set to a Vast persistent
# storage path so checkpoints survive instance shutdown:
# CHECKPOINT_DIR_BASE=/workspace/persistent/checkpoints
