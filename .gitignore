scripts/.env

# Data: eval jsonls (data/, data_subsample/) are tracked. Keep download cache
# and any parquet artifacts out (parquet are training-data leftovers from an
# earlier branch — eval pipeline reads jsonl). Training data lives at
# data/training/ and is regenerated by training/scripts/prepare_dataset.py.
data/.cache/
data/*/*.parquet
data/training/

# Results (per-run artifacts; aggregated reports live in docs/)
evaluation_search_r1/results/

# Run logs
*.log

# Autoresearch working log
results.tsv