# Python
__pycache__/
*.egg-info/
**/.DS_Store

# Local Retriever — these are symlinks to /corpus, /indexes, /models at repo root
# (set up in BOOTSTRAP_NEW_INSTANCE.md). No trailing slash so the rules match
# symlinks (which git treats as files), not just real directories.
local_retriever/corpus
local_retriever/indexes
local_retriever/models

# M3 evaluation runtime data (corpus + 16 GB IVF index + encoder model;
# sourced from /zfsstore/user/s4374886/omega/flash-rag/{corpus,models} via symlinks
# and a local 16 GB IVF-SQ8 index file — too large for git)
/corpus/
/indexes/
/models/

# Evaluation
evaluation_search_r1/search_r1_base_model/
evaluation_search_r1/search_r1_instruct_model/

# M3 evaluation: Qwen3-0.6B model checkpoints (HF safetensors, ~1.5 GB each)
eval/qwen_3_0.6b/
eval/qwen_3_0.6b_v0/
eval/qwen_3_0.6b_v0_no_ex/

# M4 evaluation: Qwen3.5-0.8B model checkpoints (HF safetensors, ~1.7 GB each).
# v1 is the "pre-M4" branch; these dirs may exist on the shared filesystem because
# the M4 worktree shares this `eval/` directory, so the rules are defensive — they
# prevent accidental tracking of large model weights from any branch.
eval/qwen3.5_0.8b/
eval/qwen3.5_0.8b_base/

# evaluation_research/: results dir (per-run artifacts; aggregated reports live in docs/)
evaluation_research/results/

# Environment
/.venv
local_retriever/.venv
scripts/.env
training/.env

# Data: eval jsonls (data/, data_subsample/) are tracked via LFS. Training
# parquets at data/training/ are also committed via LFS (see .gitattributes).
# Keep the HF download cache out.
data/.cache/

# Results (per-run artifacts; aggregated reports live in docs/)
evaluation_search_r1/results/

# Run logs
*.log
*.pid
*.pid_text

# M3 sbatch / interactive job logs (per-job stdout/stderr; large retriever + sglang traces)
logs/m3_*.out
logs/m3_*.err

# Training run artifacts (commit smoke trace jsonls explicitly; ignore W&B dirs and checkpoints)
logs/**/wandb/
results/grpo/

# Autoresearch working log
results.tsv

# Internship
docs/internship/

# Zeta Alpha meeting prep (private)
docs/zeta_alpha/

# Sankar (private)
docs/sankar/

# ALICE cluster reference (machine-specific, local-only)
docs/alice/

# Local tooling: Obsidian vault config and Claude Code workspace state
.obsidian/
.claude/
